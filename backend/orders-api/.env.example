# Copy to `.env` and fill in real values. DO NOT commit the real `.env`
# (it is gitignored at the project root).
#
# On Railway, set each of these as a project variable via:
#   Project  ->  Variables  ->  New Variable
# Railway automatically provides DATABASE_URL when you attach a Postgres
# plugin, so you only need to override it if you point at an external DB.

# ----- required -----
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# ORDERS_DATABASE_URL is a legacy alias; either variable is accepted.
ORDERS_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ----- UTF-8 / Arabic safety -----
LANG=C.UTF-8
LC_ALL=C.UTF-8
PGCLIENTENCODING=UTF8

# ----- public URL the backend advertises -----
# This is the public HTTPS URL of THIS backend (no trailing slash). Used by
# any response that needs to emit an absolute link back to itself.
# On Railway, set this to `https://<your-service>.up.railway.app`.
PUBLIC_BASE_URL=https://your-backend.up.railway.app

# ----- observability (optional) -----
SENTRY_DSN=

# ----- algolia search (optional, enable only if used) -----
ALGOLIA_ENABLED=false
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
ALGOLIA_INDEX_NAME=
ALGOLIA_INDEX_PRODUCTS=
ALGOLIA_INDEX_STORES=

# ----- firebase admin (for token verification) -----
# Base64-encoded service account JSON (recommended on Railway since it
# accepts multiline values poorly). Generated by the `gcloud` command in
# the Railway deploy guide.
FIREBASE_SERVICE_ACCOUNT_BASE64=
